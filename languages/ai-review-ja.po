#: inc/admin/class-settings-page.php
msgid "LLM Settings"
msgstr "LLM設定"

#: inc/admin/class-settings-page.php
msgid "LLM Provider (API Base URL)"
msgstr "LLMプロバイダ (API Base URL)"

#: inc/admin/class-settings-page.php
msgid "Model Name"
msgstr "モデル名"

#: inc/admin/class-settings-page.php
msgid "API Key"
msgstr "APIキー"

#: inc/admin/class-settings-page.php
msgid "System Prompt"
msgstr "システムプロンプト"

#: inc/admin/class-settings-page.php
msgid "AI Review Settings"
msgstr "AI Review 設定"

#: inc/admin/class-settings-page.php
msgid "Save Changes"
msgstr "変更を保存"

#: inc/admin/class-settings-page.php
msgid "Enter the API Base URL of your LLM provider (e.g. https://api.openai.com/v1)"
msgstr "LLMプロバイダのAPI Base URLを入力してください（例: https://api.openai.com/v1）"

#: inc/admin/class-settings-page.php
msgid "Enter the model name to use (e.g. gpt-4o-mini)"
msgstr "使用するモデル名を入力してください（例: gpt-4o-mini）"

#: inc/admin/class-settings-page.php
msgid "Enter the API key for your LLM provider"
msgstr "LLMプロバイダのAPIキーを入力してください"

#: inc/admin/class-settings-page.php
msgid "Enter the system prompt to send to the AI"
msgstr "AIに送信するシステムプロンプトを入力してください"

#: inc/admin/class-settings-page.php
msgid "Connection Test"
msgstr "接続テスト"

#: inc/admin/class-settings-page.php
msgid "Send a \"What is your name?\" request to verify your API settings."
msgstr "\"あなたの名前は？\" リクエストを送信してAPI設定を確認します。"

#: inc/admin/class-settings-page.php
msgid "Test Connection"
msgstr "接続テスト"

#: inc/admin/class-settings-page.php
msgid "Success:"
msgstr "成功:"

#: inc/admin/class-settings-page.php
msgid "Error:"
msgstr "エラー:"

#: inc/admin/class-settings-page.php
msgid "You are an excellent editor. Please correct typos and unnatural expressions. Do not modify or remove any WordPress block markup, HTML tags, or shortcodes."
msgstr "あなたは優秀な編集者です。誤字脱字や不自然な表現を修正してください。WordPressのブロックマークアップ、HTMLタグ、ショートコードは変更・削除しないでください。"

#: inc/rest/class-api-endpoint.php
msgid "What is your name?"
msgstr "あなたの名前は？"

#: inc/rest/class-api-endpoint.php
msgid "LLM settings are not configured."
msgstr "LLMの設定が完了していません。"

#: inc/rest/class-api-endpoint.php
msgid "API returned status %d"
msgstr "APIがステータス %d を返しました"

#: inc/rest/class-api-endpoint.php
msgid "LLM settings are not configured. Please configure them in the settings page."
msgstr "LLMの設定が完了していません。設定画面から設定を行ってください。"

#: inc/rest/class-api-endpoint.php
msgid ""
"Please revise the following article.\n"
"\n"
"[Title]\n"
"%1$s\n"
"\n"
"[Article]\n"
"%2$s\n"
"\n"
"[Instructions]\n"
"%3$s"
msgstr ""
"以下の記事を修正してください。\n"
"\n"
"【タイトル】\n"
"%1$s\n"
"\n"
"【記事内容】\n"
"%2$s\n"
"\n"
"【修正指示】\n"
"%3$s"

#: inc/rest/class-api-endpoint.php
msgid ""
"Please revise the following article.\n"
"\n"
"[Title]\n"
"%1$s\n"
"\n"
"[Article]\n"
"%2$s"
msgstr ""
"以下の記事を修正してください。\n"
"\n"
"【タイトル】\n"
"%1$s\n"
"\n"
"【記事内容】\n"
"%2$s"

#: inc/rest/class-api-endpoint.php
msgid "Failed to communicate with the AI service. Please try again later."
msgstr "AIサービスとの通信に失敗しました。しばらく経ってから再度お試しください。"

#: inc/rest/class-api-endpoint.php
msgid "The AI service returned an error (status: %d). Please check your settings."
msgstr "AIサービスからエラーが返されました（ステータス: %d）。設定を確認してください。"

#: inc/rest/class-api-endpoint.php
msgid "No valid response was received from the AI service."
msgstr "AIサービスから有効な応答が得られませんでした。"

#: inc/rest/class-api-endpoint.php
msgid "The AI service returned an unexpected response format."
msgstr "AIサービスから予期しないレスポンス形式が返されました。"

#: src/components/Sidebar.jsx
msgid "An error occurred."
msgstr "エラーが発生しました。"

#: src/components/Sidebar.jsx
msgid "Loading..."
msgstr "読み込み中..."

#: src/components/Sidebar.jsx
msgid "Please complete the LLM settings. Go to Settings → AI Review."
msgstr "設定画面からLLMの設定を完了してください。管理画面の「設定」→「AI Review」から設定できます。"

#: src/components/ExecuteButton.jsx
msgid "Processing..."
msgstr "処理中..."

#: src/components/ExecuteButton.jsx
msgid "Execute"
msgstr "実行"

#: src/components/WarningNotice.jsx
msgid "AI revisions will overwrite the current post content."
msgstr "⚠ AIによる修正は現在の記事内容を上書きします。"

#: src/components/ChangesNotice.jsx
msgid "Changes"
msgstr "変更内容"

#: src/components/PromptInput.jsx
msgid "Instructions (optional)"
msgstr "修正指示（任意）"

#: src/components/PromptInput.jsx
msgid "Optionally enter instructions for the AI. If left empty, the system prompt will be used as-is."
msgstr "AIへの修正指示を入力してください（空欄の場合はシステムプロンプトのみで実行されます）"

#: src/components/PromptInput.jsx
msgid "e.g. Make the tone more casual"
msgstr "例: もっとカジュアルな文体にして"

#: src/index.js
msgid "AI Review"
msgstr "AI Review"
